rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Encrypted app backups: users/{uid}/backups/{backupId}
    // Only the signed-in Firebase user whose uid matches {userId} may read or write.
    match /users/{userId}/backups/{backupId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else (do not add match /{document=**} open rules here).
  }
}
